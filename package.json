{
  "name": "watch-wishlist-sale",
  "version": "1.0.0",
  "description": "Check your Steam wishlist and notify you via Discord of the price, discount rate, and the lowest price in SteamDB.",
  "homepage": "https://github.com/tomacheese/watch-wishlist-sale",
  "bugs": {
    "url": "https://github.com/tomacheese/watch-wishlist-sale/issues"
  },
  "license": "MIT",
  "author": "Tomachi",
  "private": true,
  "main": "dist/main.js",
  "repository": {
    "type": "git",
    "url": "git@github.com:tomacheese/watch-wishlist-sale.git"
  },
  "scripts": {
    "generate-schema": "typescript-json-schema --required tsconfig.json ConfigInterface -o schema/Configuration.json",
    "lint:prettier": "prettier --check src",
    "lint:eslint": "eslint . -c eslint.config.mjs",
    "lint:tsc": "tsc",
    "fix:eslint": "eslint . -c eslint.config.mjs --fix",
    "fix:prettier": "prettier --write src",
    "preinstall": "npx only-allow pnpm",
    "start": "tsx ./src/main.ts",
    "dev": "tsx watch ./src/main.ts",
    "lint": "run-z lint:prettier,lint:eslint,lint:tsc",
    "fix": "run-z fix:prettier,fix:eslint"
  },
  "devDependencies": {
    "@book000/eslint-config": "1.14.26",
    "@book000/node-utils": "1.24.158",
    "@types/node": "24.12.2",
    "eslint": "10.3.0",
    "eslint-config-standard": "17.1.0",
    "eslint-plugin-import": "2.32.0",
    "eslint-plugin-n": "17.24.0",
    "eslint-plugin-promise": "7.3.0",
    "prettier": "3.8.3",
    "puppeteer-core": "24.42.0",
    "run-z": "2.1.0",
    "tsx": "4.21.0",
    "typescript": "5.9.3",
    "typescript-json-schema": "0.67.1"
  },
  "packageManager": "pnpm@10.33.3+sha512.a19744364a7e248b92657a4ca5973f9354d21caf982579674b1c539f32c7420c47138ad8b1254df07aba9bc782d9b3029e3db34d5dbff974326eb74dac8ff489",
  "engines": {
    "node": "v25.9.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  }
}
